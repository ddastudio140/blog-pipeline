    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (!items || items.length === 0) throw new Error('입력 데이터 없음');\nconst html = items[0].json.data;\n\nconst match = html.match(/window\\.tillerInitData\\s*=\\s*(\\{[\\s\\S]*?\\});\\s*\\n/);\nif (!match) throw new Error('tillerInitData not found');\n\nconst tillerData = JSON.parse(match[1]);\n\nconst findKeywords = (obj) => {\n  if (!obj || typeof obj !== 'object') return null;\n  if (obj.uiType === 'REALTIME_TREND_TOP' && obj.contents?.data?.keywords) {\n    return obj.contents.data.keywords;\n  }\n  for (const val of Object.values(obj)) {\n    const result = findKeywords(val);\n    if (result) return result;\n  }\n  return null;\n};\n\nconst keywords = findKeywords(tillerData);\nif (!keywords) throw new Error('keywords not found');\n\nreturn keywords.map(item => ({\n  json: {\n    rank: item.displayRank,\n    keyword: item.keyword,\n    status: item.status,\n    source: 'auto'\n  }\n}));"
      },
      "id": "d866f0f1-2262-4081-a70a-d5918182caa6",
      "name": "code_select_keyword",
      "position": [
        -544,
        -96
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const { execSync } = require('child_process');\n\n// -----------------------------------------------------------\n// 1. 기본 데이터 및 키워드 준비\n// -----------------------------------------------------------\nconst inputData = $input.first()?.json?.data || [];\nconst keyword = $node[\"merge_keyword_source\"].json.keyword;\n// 파일명에 쓸 수 있도록 공백을 언더바(_)로 치환\nconst safeKeyword = keyword ? keyword.replace(/ /g, '_') : 'no_keyword';\n\n// -----------------------------------------------------------\n// 2. 날짜 및 시간 계산 (KST 기준)\n// -----------------------------------------------------------\nconst date = new Date();\nconst kstOffset = 9 * 60; // UTC+9\nconst kstDate = new Date(date.getTime() + (kstOffset * 60 * 1000));\n\nconst yyyy = kstDate.getUTCFullYear();\nconst mm = String(kstDate.getUTCMonth() + 1).padStart(2, '0');\nconst dd = String(kstDate.getUTCDate()).padStart(2, '0');\nconst HH = String(kstDate.getUTCHours()).padStart(2, '0');\nconst MM = String(kstDate.getUTCMinutes()).padStart(2, '0');\n\n// 예: 20260125\nconst dateDir = `${yyyy}${mm}${dd}`;\n\n// -----------------------------------------------------------\n// 3. 디렉토리 생성 및 파일 경로 설정\n// -----------------------------------------------------------\nconst baseDir = '/home/node/blog-posts';\nconst targetDir = `${baseDir}/${dateDir}`; // /home/node/blog-posts/20260125\n\n// 🌟 핵심: 디렉토리가 없으면 생성 (이미 있으면 무시)\ntry {\n  execSync(`mkdir -p ${targetDir}`);\n} catch (e) {\n  console.error(`Failed to create directory: ${targetDir}`, e);\n}\n\n// 소스 파일명: 1430_서울_부동산_sources.json\nconst sourceFileName = `${HH}${MM}_${safeKeyword}_sources.json`;\nconst tempFilePath = `${targetDir}/${sourceFileName}`;\n\n// -----------------------------------------------------------\n// 4. JSON 파일 저장\n// -----------------------------------------------------------\nconst articles = inputData.map((item, index) => ({\n  번호: index + 1,\n  제목: item.title || '제목 없음',\n  본문: item.body || '본문 없음',\n  이미지: item.imge || ''\n}));\n\nconst articlesJson = JSON.stringify(articles, null, 2);\n\n// 지정한 경로에 바로 저장\nexecSync(`cat > \"${tempFilePath}\"`, { input: articlesJson });\n\n\n// -----------------------------------------------------------\n// 5. 이미지 경로 및 기타 정보 반환 (다음 노드용)\n// -----------------------------------------------------------\nconst mainImageUrl = articles[0]?.이미지 || '';\nlet extension = 'jpg';\nif (mainImageUrl) {\n  const match = mainImageUrl.match(/\\.(jpg|jpeg|png|webp|gif|bmp)($|\\?)/i);\n  if (match) extension = match[1].toLowerCase();\n}\n\n// 이미지 파일명도 동일한 규칙 적용 (1430_서울_부동산.jpg)\nconst imageFileName = `${HH}${MM}_${safeKeyword}.${extension}`;\nconst localImageFullPath = `${targetDir}/${imageFileName}`;\nconst repoImageFilePath = `posts/${dateDir}/${imageFileName}`;\n\nreturn {\n  // 기존 출력 유지\n  articles,\n  articleCount: articles.length,\n  mainImageUrl,\n  imageExtension: extension,\n  safeKeyword,\n  \n  // 🌟 업데이트된 경로 정보\n  tempFilePath,       // Gemini가 읽을 소스 파일 경로\n  \n  // 다음 단계(이미지 다운로드 및 업로드)에서 사용할 변수\n  targetDir,          // 저장된 디렉토리\n  localImageFullPath, // 저장할 이미지 전체 경로\n  repoImageFilePath,  // Git에 올릴 때 쓸 상대 경로\n  imageFileName       // 이미지 파일명\n};"
      },
