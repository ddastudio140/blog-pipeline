    {
      "parameters": {
        "jsCode": "// 사용된 키워드 목록\nconst usedKeywords = $('sheets_get_used_keywords').all()\n  .map(item => item.json.keyword?.toLowerCase().trim())\n  .filter(k => k);\n\n// 입력된 트렌드 키워드에서 중복 제거\nconst allKeywords = $('code_select_keyword').all();\n\nconst filtered = allKeywords.filter(item => {\n  const keyword = item.json.keyword?.toLowerCase().trim();\n  return !usedKeywords.includes(keyword);\n});\n\nif (filtered.length === 0) throw new Error('사용 가능한 새 키워드가 없습니다');\n\nreturn filtered;"
      },
